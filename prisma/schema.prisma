generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String           @id @default(cuid())
  email                 String           @unique
  name                  String
  passwordHash          String
  role                  UserRole
  teamId                String?
  isActive              Boolean          @default(true)
  lastLogin             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  activities            Activity[]       @relation("ActivityUser")
  assignedCustomers     Customer[]       @relation("CustomerAssignedTo")
  createdCustomers      Customer[]       @relation("CustomerCreatedBy")
  teamLeadCustomers     Customer[]       @relation("CustomerTeamLead")
  customerAccess        CustomerAccess[] @relation("CustomerAccessUser")
  customerNotes         CustomerNote[]   @relation("CustomerNoteAuthor")
  assignedPlannedVisits PlannedVisit[]   @relation("PlannedVisitAssignedTo")
  createdPlannedVisits  PlannedVisit[]   @relation("PlannedVisitCreatedBy")
  teamLeadPlannedVisits PlannedVisit[]   @relation("PlannedVisitTeamLead")
}

model Customer {
  id                       String           @id @default(cuid())
  name                     String
  company                  String?
  phone                    String
  email                    String?
  address                  String?
  probability              SalesProbability @default(MEDIUM)
  estimatedValue           Decimal?         @db.Decimal(12, 2)
  expectedCloseDate        DateTime?
  status                   CustomerStatus   @default(NEW)
  source                   CustomerSource   @default(OTHER)
  tags                     String[]
  notesText                String           @default("")
  lastContact              DateTime?
  lastContactNotes         String           @default("")
  assignedToId             String
  teamLeadId               String?
  createdById              String
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  recordNo                 String?
  recordDate               DateTime?
  city                     String?
  district                 String?
  facilityName             String?
  sector                   String?
  contactName              String?
  contactTitle             String?
  hasWhatsapp              Boolean?
  locationNote             String?
  firstContactChannel      String?
  referralSource           String?
  responsiblePerson        String?
  facilityType             String?
  currentSituation         String?
  needAnalysis             String?
  meetingSummary           String?
  roofSuitable             String?
  roofAreaM2               Float?
  transformerPowerKva      Float?
  contractPowerKw          Float?
  monthlyConsumptionKwh    Float?
  monthlyBillTl            Float?
  wantsBackupPower         Boolean?
  batteryRequested         Boolean?
  outageLoadsDescription   String?
  hasCriticalLoads         Boolean?
  criticalLoadsDescription String?
  hybridInverterPreference String?
  wantsAlternativeProposal Boolean?
  alternativeProposalNotes String?
  requestedWorkType        String?
  proposalGiven            Boolean?
  proposalDate             DateTime?
  proposalNo               String?
  proposalAmountVatExcl    Decimal?         @db.Decimal(12, 2)
  proposalAmountVatIncl    Decimal?         @db.Decimal(12, 2)
  estimatedCost            Decimal?         @db.Decimal(12, 2)
  estimatedProfit          Decimal?         @db.Decimal(12, 2)
  stage                    String?
  lastMeetingDate          DateTime?
  result                   String?
  lostReason               String?
  competitor               String?
  completedWork            String?
  contractValue            Decimal?         @db.Decimal(12, 2)
  actualCost               Decimal?         @db.Decimal(12, 2)
  actualProfit             Decimal?         @db.Decimal(12, 2)
  paymentStatus            String?
  receivedPayment          Decimal?         @db.Decimal(12, 2)
  remainingReceivable      Decimal?         @db.Decimal(12, 2)
  jobStartDate             DateTime?
  jobEndDate               DateTime?
  invoiceIssued            Boolean?
  invoiceNo                String?
  maintenanceProposal      String?
  nextFollowUpDate         DateTime?
  priority                 String?
  statusNote               String?
  siteMediaNotes           String?
  fileLink                 String?
  buildingPermit           Boolean?
  siteVisitPhotos          String[]
  visibilityScope          String           @default("assigned_only")
  visibilityUserIds        String[]
  activities               Activity[]
  assignedTo               User             @relation("CustomerAssignedTo", fields: [assignedToId], references: [id])
  createdBy                User             @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  teamLead                 User?            @relation("CustomerTeamLead", fields: [teamLeadId], references: [id])
  accessList               CustomerAccess[]
  notes                    CustomerNote[]
  plannedVisits            PlannedVisit[]

  @@index([assignedToId])
  @@index([teamLeadId])
  @@index([createdById])
  @@index([status])
  @@index([probability])
}

model CustomerNote {
  id         String    @id @default(cuid())
  customerId String
  authorId   String
  content    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  noteDate   DateTime?
  noteType   String?
  author     User      @relation("CustomerNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([authorId])
  @@index([noteDate])
}

model Activity {
  id          String       @id @default(cuid())
  customerId  String
  userId      String
  type        ActivityType
  description String
  createdAt   DateTime     @default(now())
  dueDate     DateTime?
  isCompleted Boolean      @default(false)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user        User         @relation("ActivityUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([userId])
}

model CustomerAccess {
  id         String     @id @default(cuid())
  customerId String
  userId     String
  accessType AccessType @default(VIEW)
  createdAt  DateTime   @default(now())
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user       User       @relation("CustomerAccessUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([customerId, userId])
  @@index([customerId])
  @@index([userId])
}

model PlannedVisit {
  id                String             @id @default(cuid())
  companyName       String
  contactName       String?
  phone             String?
  email             String?
  city              String?
  district          String?
  address           String?
  sector            String?
  locationNote      String?
  locationLink      String?
  remoteNotes       String?
  assignedToId      String?
  teamLeadId        String?
  createdById       String
  plannedAt         DateTime
  status            PlannedVisitStatus @default(PLANNED)
  visibilityScope   String             @default("assigned_only")
  visibilityUserIds String[]           @default([])
  visitNotes        String?
  visitResult       String?
  buildingPermit    Boolean?
  visitPhotos       String[]           @default([])
  customerId        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  assignedTo        User?              @relation("PlannedVisitAssignedTo", fields: [assignedToId], references: [id])
  createdBy         User               @relation("PlannedVisitCreatedBy", fields: [createdById], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  teamLead          User?              @relation("PlannedVisitTeamLead", fields: [teamLeadId], references: [id])

  @@index([assignedToId])
  @@index([teamLeadId])
  @@index([createdById])
  @@index([customerId])
  @@index([status])
  @@index([plannedAt])
}

enum UserRole {
  ADMIN
  SALES_MANAGER
  PROJECT_MANAGER
  SALES_REP
}

enum CustomerStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CustomerSource {
  WEBSITE
  REFERRAL
  PHONE
  EMAIL
  WALK_IN
  SOCIAL_MEDIA
  OTHER
}

enum SalesProbability {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  CREATED
  UPDATED
  NOTE_ADDED
  STATUS_CHANGED
  ASSIGNED
  CONTACTED
  NOTE
  CALL
  MEETING
  TASK
}

enum AccessType {
  VIEW
  EDIT
  FULL
}

enum PlannedVisitStatus {
  PLANNED
  VISITED
  POSTPONED
  CANCELLED
  CONVERTED
}
